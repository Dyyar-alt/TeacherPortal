@page "/admin/courses"
@model TeacherPortal.Web.Pages.Admin.Courses.IndexModel
@{
    ViewData["Title"] = "Управление курсами";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h2>📚 Управление курсами</h2>
        <a asp-page="Create" class="btn btn-primary">+ Добавить курс</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mt-3">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row mt-3">
        <div class="col-md-6">
            <div class="form-group">
                <label>Фильтр по филиалу:</label>
                <select id="filialFilter" class="form-control" onchange="applyFilter()">
                    <option value="">Все филиалы</option>
                    @foreach (var filial in Model.Filials)
                    {
                        <option value="@filial.Id" selected="@(filial.Id == Model.SelectedFilialId)">
                            @filial.Name (@filial.Address)
                        </option>
                    }
                </select>
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group">
                <label>Поиск по названию:</label>
                <input type="text" id="searchInput" class="form-control" placeholder="Введите название курса..." oninput="applyFilter()" />
            </div>
        </div>
    </div>

    <div class="table-responsive mt-3">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Название</th>
                    <th>Код</th>
                    <th>Пар</th>
                    <th>Филиал</th>
                    <th>Групп</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var course in Model.Courses)
                {
                    <tr>
                        <td>@course.Name</td>
                        <td>@course.Code</td>
                        <td>@course.TotalLessons</td>
                        <td>@course.FilialName (@course.FilialAddress)</td>
                        <td>@course.GroupsCount</td>
                        <td>
                            <a asp-page="Edit" asp-route-id="@course.Id" class="btn btn-sm btn-warning">✏️</a>
                            <a asp-page="Delete" asp-route-id="@course.Id" class="btn btn-sm btn-danger">🗑️</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        
        @if (!Model.Courses.Any())
        {
            <div class="alert alert-info mt-3">
                Курсов не найдено. <a asp-page="Create">Создайте первый курс</a>.
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function applyFilter() {
            const filialId = document.getElementById('filialFilter').value;
            const search = document.getElementById('searchInput').value;
            window.location.href = `/admin/courses?filialId=${filialId}&search=${encodeURIComponent(search)}`;
        }
    </script>
}