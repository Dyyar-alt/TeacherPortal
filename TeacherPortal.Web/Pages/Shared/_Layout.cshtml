<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Портал преподавателя</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TeacherPortal.Web.styles.css" asp-append-version="true" />

    <style>
            .navbar-brand {
                font-weight: 700;
                color: #0d6efd !important;
            }

            .nav-link:hover {
                color: #0d6efd !important;
            }

            .dropdown-item:hover {
                background-color: #e9ecef;
            }

            .footer {
                background-color: #f8f9fa;
                padding: 1.5rem 0;
            }
            /* Стили для вложенных меню (если понадобятся) */
            .dropdown-submenu {
                position: relative;
            }

                .dropdown-submenu > .dropdown-menu {
                    top: 0;
                    left: 100%;
                    margin-top: -6px;
                    margin-left: -1px;
                    border-radius: 0.375rem;
                }

                .dropdown-submenu:hover > .dropdown-menu {
                    display: block;
                }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm">
            <div class="container">
                <!-- Логотип -->
                <a class="navbar-brand" asp-page="/Index">
                    🏫 Портал преподавателя
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-lg-flex justify-content-between">
                    <!-- ======================================== -->
                    <!-- ЛЕВАЯ ЧАСТЬ: ОСНОВНОЕ МЕНЮ (Навигация) -->
                    <!-- ======================================== -->
                    <ul class="navbar-nav flex-grow-1">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <!-- Ссылки для всех авторизованных пользователей -->
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/Lessons/Counter">📊 Счетчик пар</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/Materials/ByGroup">📚 Материалы студентам</a>
                            </li>

                            <!-- АДМИН-МЕНЮ (только для администраторов) -->
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-dark" href="#" id="adminDropdown" role="button"
                                       data-bs-toggle="dropdown" aria-expanded="false">
                                        ⚙️ Администрирование
                                    </a>
                                    <ul class="dropdown-menu" aria-labelledby="adminDropdown">
                                        
                                            <li><a class="dropdown-item" href="/admin/filials">🏢 Филиалы</a></li>
                                            <li><a class="dropdown-item" href="/admin/courses">📚 Курсы</a></li>
                                            <li><a class="dropdown-item" href="/admin/groups">👥 Группы</a></li>
                                            <li><a class="dropdown-item" href="/admin/students">👨‍🎓 Студенты</a></li>
                                            
                                        <li><hr class="dropdown-divider" /></li>
                                            <li><a class="dropdown-item" href="/admin/invites">✉️ Приглашения</a></li>
                                    </ul>
                                </li>
                            }
                        }
                        else
                        {
                            <!-- Для гостей: минимум ссылок -->
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/Materials/ByGroup">📚 Материалы студентам</a>
                            </li>
                        }
                    </ul>

                    <!-- ======================================== -->
                    <!-- ПРАВАЯ ЧАСТЬ: ПРОФИЛЬ ПОЛЬЗОВАТЕЛЯ -->
                    <!-- ======================================== -->
                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-dark" href="#" id="userDropdown" role="button"
                                   data-bs-toggle="dropdown" aria-expanded="false">
                                    👤 @(User.Identity?.Name ?? "Пользователь")
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                    <!-- Информация о пользователе -->
                                    <li>
                                        <span class="dropdown-item-text text-muted">
                                            <small>
                                                @if (User.IsInRole("Admin"))
                                                {
                                                    <span class="badge bg-danger">Администратор</span>
                                                }
                                                @if (User.IsInRole("Teacher"))
                                                {
                                                    <span class="badge bg-primary">Преподаватель</span>
                                                }
                                            </small>
                                        </span>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>

                                    <!-- Пункт для будущих настроек профиля -->
                                    <li>
                                        <a class="dropdown-item" href="#" onclick="alert('Настройки профиля в разработке')">
                                            ⚙️ Настройки профиля
                                        </a>
                                    </li>

                                    <li><hr class="dropdown-divider" /></li>

                                    <!-- Выход -->
                                    <li>
                                        <form asp-page="/Account/Logout" method="post" id="logoutForm">
                                            <button type="submit" class="dropdown-item text-danger">
                                                🚪 Выйти
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <!-- Для гостей: только вход -->
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/Account/Login">🔐 Вход</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- Основной контент -->
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- Футер -->
    <footer class="border-top footer text-muted mt-5">
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    &copy; 2026 - Портал преподавателя
                </div>
                <div class="col-md-6 text-end">
                    <small>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <span>Вы вошли как <strong>@User.Identity.Name</strong></span>
                        }
                    </small>
                </div>
            </div>
        </div>
    </footer>

    <!-- Скрипты -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>