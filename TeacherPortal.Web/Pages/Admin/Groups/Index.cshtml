@page "/admin/groups"
@model TeacherPortal.Web.Pages.Admin.Groups.IndexModel
@{
    ViewData["Title"] = "Управление группами";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h2>👥 Управление группами</h2>
        <a asp-page="Create" class="btn btn-primary">+ Добавить группу</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mt-3">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row mt-3">
        <div class="col-md-4">
            <div class="form-group">
                <label>Фильтр по филиалу:</label>
                <select id="filialFilter" class="form-control" onchange="applyFilter()">
                    <option value="">Все филиалы</option>
                    @foreach (var filial in Model.Filials)
                    {
                        <option value="@filial.Id" selected="@(filial.Id == Model.SelectedFilialId)">
                            @filial.Name
                        </option>
                    }
                </select>
            </div>
        </div>
        <div class="col-md-8">
            <div class="form-group">
                <label>Фильтр по курсу:</label>
                <select id="courseFilter" class="form-control" onchange="applyFilter()">
                    <option value="">Все курсы</option>
                    @foreach (var course in Model.Courses)
                    {
                        <option value="@course.Id" selected="@(course.Id == Model.SelectedCourseId)">
                            @course.Name (@course.FilialName)
                        </option>
                    }
                </select>
            </div>
        </div>
    </div>

    <div class="table-responsive mt-3">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Название</th>
                    <th>Курс</th>
                    <th>Филиал</th>
                    <th>Студентов</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var group in Model.Groups)
                {
                    <tr>
                        <td>@group.Name</td>
                        <td>@group.CourseName</td>
                        <td>@group.FilialName</td>
                        <td>@group.StudentsCount</td>
                        <td>
                            <a asp-page="Edit" asp-route-id="@group.Id" class="btn btn-sm btn-warning">✏️</a>
                            <a asp-page="Delete" asp-route-id="@group.Id" class="btn btn-sm btn-danger">🗑️</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function applyFilter() {
            const filialId = document.getElementById('filialFilter').value;
            const courseId = document.getElementById('courseFilter').value;
            window.location.href = `/admin/groups?filialId=${filialId}&courseId=${courseId}`;
        }
    </script>
}