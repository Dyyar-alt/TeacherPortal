@page "/admin/filials/create"
@model TeacherPortal.Web.Pages.Admin.Filials.CreateModel
@{
    ViewData["Title"] = "Создание филиала";
}

<div class="container mt-4">
    <h2>➕ Создание филиала</h2>
    <hr />

    <div class="row">
        <div class="col-md-6">
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group mb-3">
                    <label asp-for="Filial.Name" class="control-label"></label>
                    <input asp-for="Filial.Name" class="form-control" />
                    <span asp-validation-for="Filial.Name" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Filial.Address" class="control-label"></label>
                    <input asp-for="Filial.Address" class="form-control" />
                    <span asp-validation-for="Filial.Address" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="Filial.Phone" class="control-label"></label>
                    <input asp-for="Filial.Phone" class="form-control" id="phoneInput" placeholder="+7 (XXX) XXX-XX-XX" />
                    <span asp-validation-for="Filial.Phone" class="text-danger"></span>
                    <small class="form-text text-muted">Формат: +7 (XXX) XXX-XX-XX</small>
                </div>


                <div class="form-group">
                    <input type="submit" value="Создать" class="btn btn-primary" />
                    <a asp-page="Index" class="btn btn-secondary">Отмена</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        (function() {
            const phoneInput = document.getElementById('phoneInput');
            if (!phoneInput) return;

            // Форматирование при вводе
            phoneInput.addEventListener('input', function(e) {
                let value = this.value.replace(/\D/g, '');

                // Если начинается с 7 или 8, убираем
                if (value.startsWith('7') || value.startsWith('8')) {
                    value = value.substring(1);
                }

                let formatted = '';
                if (value.length > 0) {
                    formatted = '+7 (';
                    if (value.length > 3) {
                        formatted += value.substring(0, 3) + ') ';
                        if (value.length > 6) {
                            formatted += value.substring(3, 6) + '-';
                            if (value.length > 8) {
                                formatted += value.substring(6, 8) + '-';
                                if (value.length > 10) {
                                    formatted += value.substring(8, 10);
                                } else {
                                    formatted += value.substring(8);
                                }
                            } else {
                                formatted += value.substring(6);
                            }
                        } else {
                            formatted += value.substring(3);
                        }
                    } else {
                        formatted += value;
                    }
                }

                // Обновляем только если изменилось
                if (this.value !== formatted) {
                    this.value = formatted;
                }
            });

            // Очистка при получении фокуса (если пусто)
            phoneInput.addEventListener('focus', function() {
                if (this.value === '') {
                    this.value = '+7 (';
                }
            });

            // Если поле пустое, ставим пустую строку
            phoneInput.addEventListener('blur', function() {
                if (this.value === '+7 (' || this.value === '+7 () ') {
                    this.value = '';
                }
            });
        })();
    </script>
}