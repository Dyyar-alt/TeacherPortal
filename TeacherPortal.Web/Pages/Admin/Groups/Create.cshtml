@page "/admin/groups/create"
@model TeacherPortal.Web.Pages.Admin.Groups.CreateModel
@{
    ViewData["Title"] = "Создание группы";
}

<div class="container mt-4">
    <h2>➕ Создание группы</h2>
    <hr />

    <div class="row">
        <div class="col-md-6">
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group mb-3">
                    <label asp-for="Group.Name" class="control-label"></label>
                    <input asp-for="Group.Name" class="form-control" />
                    <span asp-validation-for="Group.Name" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Group.CourseId" class="control-label"></label>
                    <select asp-for="Group.CourseId" class="form-control" asp-items="Model.Courses">
                        <option value="">-- Выберите курс --</option>
                    </select>
                    <span asp-validation-for="Group.CourseId" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <input type="submit" value="Создать" class="btn btn-primary" />
                    <a asp-page="Index" class="btn btn-secondary">Отмена</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}