@page "/account/register"
@model TeacherPortal.Web.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Регистрация";
}

<div class="container mt-5" style="max-width: 400px;">
    <div class="card shadow">
        <div class="card-header bg-success text-white">
            <h4>📝 Регистрация преподавателя</h4>
        </div>
        <div class="card-body">
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger">@Model.ErrorMessage</div>
            }
            @if (!string.IsNullOrEmpty(Model.SuccessMessage))
            {
                <div class="alert alert-success">@Model.SuccessMessage</div>
            }

            <form method="post">
                <div class="form-group mb-3">
                    <label asp-for="Input.FullName">Полное имя</label>
                    <input asp-for="Input.FullName" class="form-control" required />
                    <span asp-validation-for="Input.FullName" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="Input.Email">Email</label>
                    <input asp-for="Input.Email" class="form-control" required />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="Input.Password">Пароль</label>
                    <input asp-for="Input.Password" type="password" class="form-control" required />
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="Input.ConfirmPassword">Подтверждение пароля</label>
                    <input asp-for="Input.ConfirmPassword" type="password" class="form-control" required />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                </div>
                <button type="submit" class="btn btn-success w-100">Зарегистрироваться</button>
            </form>

            <div class="mt-3 text-center">
                <a href="/account/login">Уже есть аккаунт? Войти</a>
            </div>
        </div>
    </div>
</div>