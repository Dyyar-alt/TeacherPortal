@page "/admin/students/create"
@model TeacherPortal.Web.Pages.Admin.Students.CreateModel
@{
    ViewData["Title"] = "Добавление студента";
}

<div class="container mt-4">
    <h2>➕ Добавление студента</h2>
    <hr />

    <div class="row">
        <div class="col-md-6">
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group mb-3">
                    <label asp-for="Student.Password" class="control-label"></label>
                    <input asp-for="Student.Password" type="password" class="form-control" />
                    <span asp-validation-for="Student.Password" class="text-danger"></span>
                    <small class="form-text text-muted">Оставьте пустым, чтобы сгенерировать пароль автоматически.</small>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Student.FullName" class="control-label"></label>
                    <input asp-for="Student.FullName" class="form-control" />
                    <span asp-validation-for="Student.FullName" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Student.Email" class="control-label"></label>
                    <input asp-for="Student.Email" class="form-control" />
                    <span asp-validation-for="Student.Email" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Student.GroupId" class="control-label"></label>
                    <select asp-for="Student.GroupId" class="form-control" asp-items="Model.Groups">
                        <option value="">-- Выберите группу --</option>
                    </select>
                    <span asp-validation-for="Student.GroupId" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <input type="submit" value="Добавить" class="btn btn-primary" />
                    <a asp-page="Index" class="btn btn-secondary">Отмена</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}