@page "/account/login"
@model TeacherPortal.Web.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Вход в систему";
}

<div class="container mt-5" style="max-width: 400px;">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h4>🔐 Вход в портал преподавателя</h4>
        </div>
        <div class="card-body">
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger">@Model.ErrorMessage</div>
            }

            <form method="post">
                <div class="form-group mb-3">
                    <label asp-for="Input.Email">Email</label>
                    <input asp-for="Input.Email" class="form-control" required />
                </div>
                <div class="form-group mb-3">
                    <label asp-for="Input.Password">Пароль</label>
                    <input asp-for="Input.Password" type="password" class="form-control" required />
                </div>
                <div class="form-group form-check mb-3">
                    <input asp-for="Input.RememberMe" class="form-check-input" />
                    <label asp-for="Input.RememberMe" class="form-check-label">Запомнить меня</label>
                </div>
                <button type="submit" class="btn btn-primary w-100">Войти</button>
            </form>

            <div class="mt-3 text-center">
                <a href="/account/register">Нет аккаунта? Зарегистрироваться</a>
            </div>
        </div>
    </div>
</div>