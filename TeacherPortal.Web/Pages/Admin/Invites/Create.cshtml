@page "/admin/invites/create"
@model TeacherPortal.Web.Pages.Admin.Invites.CreateModel
@{
    ViewData["Title"] = "Добавить преподавателя";
}

<div class="container mt-4">
    <h2>➕ Добавить email преподавателя</h2>
    <hr />

    <div class="row">
        <div class="col-md-6">
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                
                <div class="form-group mb-3">
                    <label asp-for="Email" class="control-label">Email преподавателя</label>
                    <input asp-for="Email" class="form-control" placeholder="teacher@college.edu" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                    <small class="form-text text-muted">После добавления преподаватель сможет зарегистрироваться, используя этот email.</small>
                </div>
                
                <div class="form-group">
                    <input type="submit" value="Добавить" class="btn btn-primary" />
                    <a asp-page="Index" class="btn btn-secondary">Отмена</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}