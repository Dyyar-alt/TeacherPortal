@page "/materials/by-group"
@model TeacherPortal.Web.Pages.Materials.ByGroupModel
@{
    ViewData["Title"] = "Материалы для студентов";
}

<div class="container mt-4">
    <h2>📚 Материалы по группам</h2>

    <!-- Форма выбора группы -->
    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5>Выберите вашу группу</h5>
                </div>
                <div class="card-body">
                    <form method="get">
                        <div class="form-group">
                            <label for="groupId">Группа:</label>
                            <select id="groupId" name="groupId" class="form-control" onchange="this.form.submit()">
                                <option value="">-- Выберите группу --</option>
                                @foreach (var group in Model.Groups)
                                {
                                    <option value="@group.Id" selected="@(group.Id == Model.SelectedGroupId)">
                                        @group.Name - @group.CourseName
                                    </option>
                                }
                            </select>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Отображение материалов -->
    @if (Model.Lessons != null && Model.Lessons.Any())
    {
        <div class="row mt-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-success text-white">
                        <h5>
                            @Model.GroupName - @Model.CourseName
                            <span class="badge bg-light text-dark float-end">Пар: @Model.Lessons.Count</span>
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="accordion" id="lessonsAccordion">
                            @foreach (var lesson in Model.Lessons)
                            {
                                <div class="accordion-item">
                                    <h2 class="accordion-header" id="heading-@lesson.Id">
                                        <button class="accordion-button @(lesson.Materials.Any() ? "" : "collapsed")"
                                                type="button"
                                                data-bs-toggle="collapse"
                                                data-bs-target="#collapse-@lesson.Id"
                                                aria-expanded="@(lesson.Materials.Any() ? "true" : "false")"
                                                aria-controls="collapse-@lesson.Id">
                                            <div class="d-flex w-100 justify-content-between">
                                                <span>
                                                    <strong>Пара №@lesson.LessonNumber</strong>
                                                    @if (!string.IsNullOrEmpty(lesson.Topic))
                                                    {
                                                        <span class="text-muted ms-2">— @lesson.Topic</span>
                                                    }
                                                </span>
                                                <span>
                                                    @if (lesson.DateIssued.HasValue)
                                                    {
                                                        <small class="text-muted me-3">
                                                            📅 @lesson.DateIssued.Value.ToString("dd.MM.yyyy")
                                                        </small>
                                                    }
                                                    <span class="badge bg-info">@lesson.Materials.Count файлов</span>
                                                </span>
                                            </div>
                                        </button>
                                    </h2>
                                    <div id="collapse-@lesson.Id"
                                         class="accordion-collapse collapse @(lesson.Materials.Any() ? "show" : "")"
                                         aria-labelledby="heading-@lesson.Id"
                                         data-bs-parent="#lessonsAccordion">
                                        <div class="accordion-body">
                                            @if (lesson.Materials.Any())
                                            {
                                                <div class="list-group">
                                                    @foreach (var material in lesson.Materials)
                                                    {
                                                        <a href="@material.FilePath"
                                                           target="_blank"
                                                           class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                                            <div>
                                                                <strong>@material.Title</strong>
                                                                @if (!string.IsNullOrEmpty(material.Description))
                                                                {
                                                                    <br />
                                                                    <small class="text-muted">@material.Description</small>
                                                                }
                                                            </div>
                                                            <span class="badge bg-secondary">
                                                                📎 @material.FileName
                                                            </span>
                                                        </a>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <p class="text-muted">Материалов для этой пары пока нет.</p>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (Model.SelectedGroupId.HasValue && !Model.Lessons.Any())
    {
        <div class="alert alert-info mt-4">
            Для выбранной группы пока нет выданных пар или материалов.
        </div>
    }
</div>

@section Scripts {
    <script>
        // Добавляем стиль для плавного раскрытия
        document.addEventListener('DOMContentLoaded', function() {
            // Если нет материалов, автоматически сворачиваем все аккордеоны
            @if (Model.Lessons != null && Model.Lessons.Any() && Model.Lessons.All(l => !l.Materials.Any()))
                {
                    <text>
                                document.querySelectorAll('.accordion-collapse').forEach(el => {
                                el.classList.remove('show');
                                });
                                document.querySelectorAll('.accordion-button').forEach(el => {
                                el.classList.add('collapsed');
                            el.setAttribute('aria-expanded', 'false');
                                });
                    </text>
            }
                });
    </script>
}