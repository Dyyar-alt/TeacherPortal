@page "/filials/select"
@model TeacherPortal.Web.Pages.Filials.SelectModel
@{
    ViewData["Title"] = "Выбор филиала";
}

<div class="container mt-5" style="max-width: 700px;">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-primary text-white text-center py-3">
            <h2>🏢 Выберите ваш филиал</h2>
            <p class="mb-0">Для продолжения работы выберите филиал, в котором вы преподаете</p>
        </div>
        <div class="card-body">
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger">@Model.ErrorMessage</div>
            }

            <form method="post">
                <div class="row g-3">
                    @foreach (var filial in Model.Filials)
                    {
                        <div class="col-md-6">
                            <button type="submit"
                                    name="filialId"
                                    value="@filial.Id"
                                    class="btn btn-outline-primary w-100 py-3 text-start shadow-sm hover-shadow">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>@filial.Name</strong>
                                        @if (!string.IsNullOrEmpty(filial.Address))
                                        {
                                            <br />
                                            <small class="text-muted">📍 @filial.Address</small>
                                        }
                                        @if (!string.IsNullOrEmpty(filial.Phone))
                                        {
                                            <br />
                                            <small class="text-muted">📞 @filial.Phone</small>
                                        }
                                    </div>
                                    <span style="font-size: 24px;">→</span>
                                </div>
                            </button>
                        </div>
                    }
                </div>
            </form>

            <div class="text-center mt-4">
                <small class="text-muted">Выберите филиал, чтобы начать работу с порталом</small>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-shadow:hover {
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
        transform: translateY(-2px);
        transition: all 0.2s ease;
        background-color: #f8f9fa !important;
    }
</style>